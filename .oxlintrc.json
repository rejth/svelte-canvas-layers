{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "import",
    "typescript",
    "jest",
    "oxc"
  ],
  "rules": {
    "no-console": "off",
    "no-debugger": "error"
  },
  "overrides": [
    {
      "files": ["**/*.svelte"],
      "rules": {
        "eslint/no-unassigned-vars": "off",
        "eslint/no-unused-expressions": "off"
      }
    }
  ],
  "env": {
    "browser": true,
    "es2022": true,
    "svelte": true
  },
  "ignorePatterns": [
    "src/wasm/**",
    "storybook-static/**"
  ]
}
