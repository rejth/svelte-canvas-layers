{
  "name": "svelte-canvas-layers",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:app": "vite",
    "dev:storybook": "pnpm --filter @canvas/storybook storybook",
    "build": "pnpm build:app",
    "build:app": "vite build --outDir dist/app",
    "build:storybook": "pnpm --filter @canvas/storybook build",
    "build:deploy": "pnpm build:app && pnpm build:storybook",
    "preview": "pnpm preview:app",
    "preview:app": "vite preview --outDir dist/app",
    "preview:storybook": "vite preview --outDir packages/storybook/dist --port 6007",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "pnpm oxlint src",
    "lint:fix": "pnpm oxlint src --fix",
    "format": "pnpm biome format --write src",
    "format:check": "pnpm biome check --write src",
    "check-updates": "pnpm npm-check-updates",
    "update-packages": "pnpm npm-check-updates -u",
    "knip": "knip",
    "pre-commit": "pnpm lefthook run pre-commit",
    "pre-push": "pnpm lefthook run pre-push"
  },
  "dependencies": {
    "@canvas/engine": "workspace:*",
    "canvas-size": "^2.0.0",
    "perfect-arrows": "^0.3.7",
    "uuid": "^11.0.2",
    "yieldkit": "^0.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@sveltejs/vite-plugin-svelte": "^3.0.1",
    "@tsconfig/svelte": "^5.0.4",
    "@types/canvas-size": "^1.2.2",
    "@types/node": "^22.8.6",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.20",
    "bits-ui": "^0.21.16",
    "clsx": "^2.1.1",
    "knip": "^5.34.4",
    "lefthook": "^1.8.2",
    "lucide-svelte": "^0.456.0",
    "npm-check-updates": "^17.1.9",
    "oxlint": "1.57.0",
    "svelte": "^4.2.8",
    "svelte-check": "^3.6.2",
    "tailwind-merge": "^2.5.4",
    "tailwind-variants": "^0.2.1",
    "tailwindcss": "^3.4.9",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  },
  "packageManager": "pnpm@9.15.4"
}
